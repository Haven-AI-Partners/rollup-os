{
  "name": "rollup-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "auditIgnoreNotes": "13 transitive vulns in trigger.dev and drizzle-kit are not exploitable in our context (dev tools, build tooling, no user input). Will resolve naturally when those packages update."
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:add-member": "tsx src/lib/db/add-member.ts",
    "db:seed-demo": "tsx src/lib/db/seed-demo-data.ts",
    "db:reset-demo": "tsx src/lib/db/reset-demo-data.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/moonshotai": "^2.0.12",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/react": "^3.0.118",
    "@clerk/nextjs": "^7.0.7",
    "@clerk/ui": "^1.2.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-virtual": "^3.13.23",
    "@trigger.dev/sdk": "^4.4.3",
    "@types/pdf-parse": "^1.1.5",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.138",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^171.4.0",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "svix": "^1.86.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-security": "^4.0.0",
    "jscpd": "^4.0.8",
    "jsdom": "^29.0.1",
    "madge": "^8.0.0",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4",
    "trigger.dev": "^4.4.3",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
