# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Encryption (for GDrive service account keys at rest)
GOOGLE_DRIVE_ENCRYPTION_KEY=your-32-byte-hex-key

# Trigger.dev
# Per-environment key that routes tasks.trigger() calls to the correct environment.
# Get from: Trigger.dev dashboard > Project > Environment > API Keys
# Dev keys start with tr_dev_..., prod keys start with tr_prod_...
# Also set in Trigger.dev dashboard for task runtime + Vercel for SDK routing.
TRIGGER_SECRET_KEY=tr_dev_...

# Google AI (Gemini) – used by @ai-sdk/google for IM/DD processing agents
# Also needed in Trigger.dev dashboard (tasks use Gemini for analysis).
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Google OAuth (for GDrive browser-based connect flow only – NOT needed by Trigger.dev tasks)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gdrive/callback
